# Frontend (Vite)
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=

# Trigger.dev local worker (npx trigger.dev@latest dev)
# Get service role key from Supabase Dashboard → Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Must match Supabase Edge Functions secret ENCRYPTION_KEY (required for MCP auth decrypt)
ENCRYPTION_KEY=
# Same value as ENCRYPTION_KEY — frontend ActiveCollab credential encrypt (Vite)
VITE_ENCRYPTION_KEY=
